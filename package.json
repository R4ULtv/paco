{
  "name": "paco",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun run build.ts --watch",
    "typecheck": "bun x tsc --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "bun run typecheck && bun run lint && bun run format:check"
  },
  "dependencies": {
    "dexie": "^4.4.2"
  },
  "devDependencies": {
    "@types/bun": "1.3.12",
    "@types/chrome": "0.1.40",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.3.11"
}
