{
  "manifest_version": 3,
  "name": "Paco",
  "version": "0.2.0",
  "description": "Paco remembers what YouTube keeps repeating to you.",
  "icons": {
    "16": "assets/paco-16.png",
    "32": "assets/paco-32.png",
    "48": "assets/paco-48.png",
    "128": "assets/paco-128.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["paco.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"],
  "host_permissions": ["*://www.youtube.com/*"]
}
